# App Configuration
APP_NAME="My Saas Backend"
DEBUG=false
ENVIRONMENT=production  # development | staging | production

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database (if using db feature)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/my-saas-backend
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Redis (if using redis feature)
REDIS_URL=redis://localhost:6379/0

# Auth (if using auth feature)
JWT_SECRET=your-secret-key-at-least-32-characters-long
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# Stripe (if using stripe feature)
STRIPE_API_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# CORS
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Logging
LOG_LEVEL=INFO
